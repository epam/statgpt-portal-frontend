{
  "name": "statgpt-portal-frontend",
  "version": "0.2.0-rc",
  "license": "MIT",
  "scripts": {
    "build": "nx run-many -t build && npm run build:styles",
    "start": "nx serve portals-example --port=4001",
    "test": "nx run-many -t test --runInBand",
    "test:verbose": "nx run-many -t test --runInBand --output-style=stream",
    "lint": "nx run-many --target=lint --all",
    "lint:fix": "nx run-many --target=lint --all --fix",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "typecheck": "nx run-many --target=typecheck --all",
    "graph": "nx graph",
    "build:styles": "tailwindcss -m -i ./libs/ui-components/src/scss/styles.scss -o ./dist/libs/ui-components/index.css",
    "publish": "nx run-many -t publish",
    "publish:dry": "nx run-many -t publish --output-style=static --dry",
    "affected:build": "nx affected --target=build",
    "affected:test": "nx affected --target=test",
    "affected:lint": "nx affected --target=lint"
  },
  "private": true,
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
