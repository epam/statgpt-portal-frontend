    "next": "^15.5.10",
    "next-auth": "^4.24.12",
    "next-international": "^1.3.1",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-flatpickr": "^4.0.11",
    "react-markdown": "^10.1.0",
    "react-virtualized-auto-sizer": "^1.0.26",
    "react-window": "^1.8.11",
    "remark-gfm": "^4.0.1",
