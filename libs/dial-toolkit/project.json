{
  "name": "dial-toolkit",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/dial-toolkit/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/vite:build",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/libs/dial-toolkit"
      },
      "configurations": {
        "development": {
          "mode": "development"
        },
        "production": {
          "mode": "production"
        }
      }
    },

    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": [
          "libs/dial-toolkit/src",
          "libs/dial-toolkit/package.json"
        ]
      }
    },
    "publish": {
      "command": "node tools/publish-lib.mjs dial-toolkit --version={args.ver} --dry={args.dry} --tag={args.tag} --development={args.development}"
    }
  }
}
